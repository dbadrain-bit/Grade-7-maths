# Environment Variables Template
# Copy this to .env and fill in your actual values

# Server Configuration
NODE_ENV=development
PORT=5000

# JWT Secret for token signing (change in production!)
JWT_SECRET=your-super-secret-key-change-this-in-production

# Google Gemini API Key for AI chatbot
# Store your real API key in a local .env file; do NOT commit secrets to git
# Example: GEMINI_API_KEY=your-google-gemini-api-key-here
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_API_KEY

# Supabase Configuration
# Store your real Supabase credentials in a local .env file; do NOT commit secrets to git
# Example: SUPABASE_URL=https://your-project.supabase.co
# Example: SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_URL=REPLACE_WITH_SUPABASE_URL
SUPABASE_ANON_KEY=REPLACE_WITH_SUPABASE_ANON_KEY
